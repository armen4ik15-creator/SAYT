# ── Сервер ──
PORT=3000
NODE_ENV=production

# ── Безопасность ──
# Сгенерируйте свой секрет: openssl rand -hex 32
JWT_SECRET=замените-на-длинную-случайную-строку-минимум-32-символа

# ── Учётка администратора ──
# Логин и пароль для входа в /admin.html
# Пароль будет автоматически захеширован при первом запуске
ADMIN_LOGIN=admin
ADMIN_PASSWORD=ChangeMe2026!

# ── База данных Timeweb (опционально, если не задано — используется JSON-файл) ──
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_TYPE=postgres

# ── Контакты для заявок ──
NOTIFY_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
